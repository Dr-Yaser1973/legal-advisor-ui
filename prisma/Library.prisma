 // تعريف جميع نماذج المكتبة هنا

enum LibraryMainCategory {
  LAW
  FIQH
  ACADEMIC
  CONTRACT
}

enum LibraryItemType {
  CONSTITUTION
  STATUTE
  REGULATION
  PHD_THESIS
  MASTER_THESIS
  RESEARCH_PAPER
  LOCAL_CONTRACT
  INTERNATIONAL_CONTRACT
  COURT_RULING
}

enum LibraryRelationType {
  AMENDS
  REPEALS
  INTERPRETS
  REFERENCES
  RELATED
}

model LibraryItem {
  id            String   @id @default(cuid())
  
  titleAr       String
  titleEn       String?
  
  abstractAr    String?  @db.Text
  abstractEn    String?  @db.Text
  
  basicExplanation    String? @db.Text
  professionalExplanation String? @db.Text
  commercialExplanation String? @db.Text
  
  mainCategory  LibraryMainCategory
  subCategory   String?
  itemType      LibraryItemType
  
  hasPDF        Boolean  @default(false)
  pdfUrl        String?
  hasWord       Boolean  @default(false)
  wordUrl       String?
  
  jurisdiction  String?
  year          Int?
  author        String?
  university    String?
  
  keywords      String[]
  
  views         Int      @default(0)
  downloads     Int      @default(0)
  saves         Int      @default(0)
  rating        Float    @default(0)
  
  isPublished   Boolean  @default(true)
  publishedAt   DateTime?
  
  documents     LegalDocument[] // هذا سيرتبط بعد تحميل النماذج
  
  createdById   Int?
  createdBy     User?    @relation(fields: [createdById], references: [id])
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([mainCategory])
  @@index([jurisdiction, year])
  @@index([views])
}

model LibraryRelation {
  id          String            @id @default(cuid())
  fromItemId  String
  toItemId    String
  relationType LibraryRelationType
  fromItem    LibraryItem       @relation("FromLibraryItem", fields: [fromItemId], references: [id], onDelete: Cascade)
  toItem      LibraryItem       @relation("ToLibraryItem", fields: [toItemId], references: [id], onDelete: Cascade)

  @@unique([fromItemId, toItemId, relationType])
}

model LibraryItemTag {
  itemId    String
  tagId     Int
  item      LibraryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tag       Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([itemId, tagId])
}

model LibraryRating {
  id        String   @id @default(cuid())
  itemId    String
  userId    Int
  rating    Int
  review    String?  @db.Text
  item      LibraryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([itemId, userId])
}

model LibraryFavorite {
  id        String   @id @default(cuid())
  itemId    String
  userId    Int
  item      LibraryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([itemId, userId])
}

model LibraryNote {
  id        String   @id @default(cuid())
  itemId    String
  userId    Int
  content   String   @db.Text
  page      Int?
  item      LibraryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LibraryItemDocument {
  id              Int           @id @default(autoincrement())
  libraryItemId   String
  documentId      Int
  libraryItem     LibraryItem   @relation(fields: [libraryItemId], references: [id], onDelete: Cascade)
  document        LegalDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([libraryItemId, documentId])
}